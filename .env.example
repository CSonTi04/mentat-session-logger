# Environment variables for mentat-session-logger
#
# Copy this file to .env and adjust values for your deployment.
# Variables that are not set (or are empty) fall back to the values
# configured in envs/<name>/config.yml.
#
# Factor III – Config (https://12factor.net/config):
# All deploy-time settings that differ between environments or machines
# should be supplied here rather than hard-coded in YAML files.

# ── LLM backend ──────────────────────────────────────────────────────────────
# Provider identifier (currently only "ollama" is supported).
# MSL_LLM_PROVIDER=ollama

# Full URL of the LLM API endpoint.
# MSL_LLM_ENDPOINT=http://localhost:11434/api/generate

# Model name passed to the LLM backend.
# MSL_LLM_MODEL=llama3.1:8b

# ── Speech recognition ───────────────────────────────────────────────────────
# ISO 639-1 language code used by the ASR (Whisper) backend.
# MSL_ASR_LANGUAGE=hu

# Speaker count hints for the diarization pipeline.
# MSL_MIN_SPEAKERS=4
# MSL_MAX_SPEAKERS=8

# Hugging Face token required for speaker diarization via pyannote.
# HF_TOKEN=hf_...

# ── Output ────────────────────────────────────────────────────────────────────
# ISO 639-1 language code for LLM-generated text (summaries, notes, etc.).
# MSL_OUTPUT_LANGUAGE=hu

# ── Pipeline ─────────────────────────────────────────────────────────────────
# Name of the pipeline configuration used when --pipeline is not supplied.
# MSL_DEFAULT_PIPELINE=default

# ── External tools ────────────────────────────────────────────────────────────
# Path (or name) of the ffmpeg binary. Useful when ffmpeg is not on PATH or
# when pointing at a specific build (e.g. a GPU-accelerated one).
# MSL_FFMPEG_BIN=ffmpeg

# ── Torch / CUDA ──────────────────────────────────────────────────────────────
# PyTorch device used by WhisperX (and the alignment model).
# When not set, CUDA is used automatically if available, otherwise CPU.
# Override only when you need a specific device, e.g. for a multi-GPU machine.
# MSL_TORCH_DEVICE=cpu

# ── LLM timeouts ──────────────────────────────────────────────────────────────
# Request timeout in seconds for the LLM backend.
# Increase when running large models that take longer than 120 s to respond.
# MSL_LLM_TIMEOUT=120
